# Twitch OAuth token (without the "OAuth " prefix)
TWITCH_OAUTH=your_twitch_oauth_token_here

# Healthchecks.io UUID (used for hc-ping.com)
HC_UUID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Local Healthchecks-compatible ping base URL (no trailing slash)
HC_LOCAL_PING_URL=http://192.168.x.x:8000/ping/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Host paths (used by docker-compose volume mounts and the postproc-trigger image)
VOD_DIR=/path/to/vod/directory
TEST_DIR=/path/to/test/directory
CONTACT_SHEETS_DIR=/path/to/contact-sheets/output
TWITCH_DIR=/path/to/twitch/root
